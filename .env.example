# From Duffel Dashboard when creating a webhook (required for POST /api/v1/webhooks/duffel)
DUFFEL_WEBHOOK_SECRET=

# Flight checkout — Duffel PaymentIntent gross-up (see Duffel “Collecting customer card payments”).
FLIGHT_COMMISSION_PERCENT=5
FLIGHT_MARKUP_FIXED=0
# Assumed card fee for (fare+markup)/customer currency; domestic vs intl may differ — tune per Duffel dashboard.
DUFFEL_PAYMENTS_FEE_RATE=0.029
# 1 when customer pays in same currency as offer; otherwise mid-market × small buffer per Duffel guide.
FLIGHT_PAYMENT_FX_RATE=1
# Max drift between PaymentIntent snapshot and refreshed offer total (major units) before order.
FLIGHT_PRICE_TOLERANCE_MAJOR=2
# Default flight PSP (only duffel_payments implemented).
FLIGHT_PAYMENT_PROVIDER=duffel_payments

